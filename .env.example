DATABASE_URL="postgresql://user:password@localhost:5432/modusho?schema=public"
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# --- Object Storage (S3/R2 compatible) ---
# Primary target: Cloudflare R2
# Also compatible with AWS S3, MinIO, DigitalOcean Spaces
S3_ENDPOINT="https://your-account-id.r2.cloudflarestorage.com"
S3_REGION="auto"
S3_ACCESS_KEY_ID="your-access-key-id"
S3_SECRET_ACCESS_KEY="your-secret-access-key"
S3_BUCKET="modusho-files"
# Set to "true" for MinIO or other path-style-only providers
S3_FORCE_PATH_STYLE="false"
