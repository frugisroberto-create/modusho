generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OPERATOR
  HOD
  HOTEL_MANAGER
  ADMIN
  SUPER_ADMIN
}

enum ContentType {
  SOP
  DOCUMENT
  MEMO
  BRAND_BOOK
  STANDARD_BOOK
}

enum ContentStatus {
  DRAFT
  REVIEW_HM
  REVIEW_ADMIN
  PUBLISHED
  RETURNED
  ARCHIVED
}

enum ReviewAction {
  APPROVED
  RETURNED
  FORWARDED
}

enum StaticDocumentType {
  BRAND_BOOK
  STANDARD_BOOK
}

enum TargetType {
  ROLE
  DEPARTMENT
  USER
}

enum AttachmentKind {
  IMAGE
  DOCUMENT
}

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  name         String
  passwordHash String
  role         Role    @default(OPERATOR)
  canView      Boolean @default(true)
  canEdit      Boolean @default(false)
  canApprove   Boolean @default(false)
  isActive     Boolean @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  propertyAssignments  PropertyAssignment[]
  contentPermissions   UserContentPermission[]
  createdContents      Content[]              @relation("ContentCreatedBy")
  updatedContents      Content[]              @relation("ContentUpdatedBy")
  submittedContents    Content[]              @relation("ContentSubmittedBy")
  deletedContents      Content[]              @relation("ContentDeletedBy")
  featuredContents     Content[]              @relation("ContentFeaturedBy")
  acknowledgments      ContentAcknowledgment[]
  reviews              ContentReview[]
  statusChanges        ContentStatusHistory[] @relation("StatusChangedBy")
  contentRevisions     ContentRevision[]      @relation("ContentRevisedBy")
  contentNotes         ContentNote[]          @relation("ContentNoteAuthor")
  targetedContents     ContentTarget[]        @relation("ContentTargetUser")
  attachments          Attachment[]           @relation("AttachmentUploadedBy")

  @@index([role])
  @@index([email])
}

model UserContentPermission {
  id          String      @id @default(cuid())
  userId      String
  contentType ContentType

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, contentType])
  @@index([userId])
}

model Property {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  tagline     String?
  city        String
  address     String?
  description String?  @db.Text
  website     String?
  logoUrl     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  departments         Department[]
  propertyAssignments PropertyAssignment[]
  contents            Content[]
  memos               Memo[]
  staticDocuments     StaticDocument[]

  @@index([code])
}

model Department {
  id         String   @id @default(cuid())
  name       String
  code       String
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])

  propertyAssignments PropertyAssignment[]
  contents            Content[]
  contentTargets      ContentTarget[]       @relation("ContentTargetDepartment")

  @@unique([propertyId, code])
  @@index([propertyId])
}

model PropertyAssignment {
  id           String      @id @default(cuid())
  userId       String
  propertyId   String
  departmentId String?

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  department Department? @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId, departmentId])
  @@index([userId])
  @@index([propertyId])
  @@index([departmentId])
}

model Content {
  id           String        @id @default(cuid())
  code         String?       @unique
  type         ContentType
  title        String
  body         String
  fileUrl      String?
  status       ContentStatus @default(DRAFT)
  version      Int           @default(1)
  propertyId   String
  departmentId String?
  createdById   String
  updatedById   String
  submittedById String?
  isFeatured    Boolean       @default(false)
  featuredAt    DateTime?
  featuredById  String?
  isDeleted     Boolean       @default(false)
  deletedAt     DateTime?
  deletedById   String?
  publishedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  property    Property    @relation(fields: [propertyId], references: [id])
  department  Department? @relation(fields: [departmentId], references: [id])
  createdBy   User        @relation("ContentCreatedBy", fields: [createdById], references: [id])
  updatedBy   User        @relation("ContentUpdatedBy", fields: [updatedById], references: [id])
  submittedBy User?       @relation("ContentSubmittedBy", fields: [submittedById], references: [id])
  featuredBy  User?       @relation("ContentFeaturedBy", fields: [featuredById], references: [id])
  deletedBy   User?       @relation("ContentDeletedBy", fields: [deletedById], references: [id])

  acknowledgments  ContentAcknowledgment[]
  reviews          ContentReview[]
  statusHistory    ContentStatusHistory[]
  targetAudience   ContentTarget[]
  revisions        ContentRevision[]
  notes            ContentNote[]
  attachments      Attachment[]
  memo             Memo?

  @@index([propertyId])
  @@index([departmentId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@index([publishedAt])
  @@index([propertyId, status])
  @@index([propertyId, departmentId, status])
  @@index([propertyId, type, status])
}

model ContentAcknowledgment {
  id             String   @id @default(cuid())
  contentId      String
  userId         String
  acknowledgedAt DateTime @default(now())
  required       Boolean  @default(true)

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([contentId, userId])
  @@index([contentId])
  @@index([userId])
}

model ContentReview {
  id         String       @id @default(cuid())
  contentId  String
  reviewerId String
  action     ReviewAction
  note       String?
  createdAt  DateTime     @default(now())

  content  Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  reviewer User    @relation(fields: [reviewerId], references: [id])

  @@index([contentId])
  @@index([reviewerId])
}

model ContentStatusHistory {
  id          String         @id @default(cuid())
  contentId   String
  fromStatus  ContentStatus?
  toStatus    ContentStatus
  changedById String
  changedAt   DateTime       @default(now())
  note        String?

  content   Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  changedBy User    @relation("StatusChangedBy", fields: [changedById], references: [id])

  @@index([contentId])
  @@index([changedById])
  @@index([changedAt])
}

model ContentRevision {
  id             String        @id @default(cuid())
  contentId      String
  revisedById    String
  previousTitle  String
  previousBody   String        @db.Text
  newTitle       String
  newBody        String        @db.Text
  note           String?
  status         ContentStatus
  createdAt      DateTime      @default(now())

  content   Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  revisedBy User    @relation("ContentRevisedBy", fields: [revisedById], references: [id])

  @@index([contentId, createdAt])
}

model ContentNote {
  id        String   @id @default(cuid())
  contentId String
  authorId  String
  body      String   @db.Text
  createdAt DateTime @default(now())

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  author  User    @relation("ContentNoteAuthor", fields: [authorId], references: [id])

  @@index([contentId, createdAt])
  @@index([authorId])
}

model ContentTarget {
  id                 String      @id @default(cuid())
  contentId          String
  targetType         TargetType
  targetRole         Role?
  targetDepartmentId String?
  targetUserId       String?
  createdAt          DateTime    @default(now())

  content          Content     @relation(fields: [contentId], references: [id], onDelete: Cascade)
  targetDepartment Department? @relation("ContentTargetDepartment", fields: [targetDepartmentId], references: [id])
  targetUser       User?       @relation("ContentTargetUser", fields: [targetUserId], references: [id])

  @@index([contentId])
}

model Memo {
  id        String    @id @default(cuid())
  contentId String    @unique
  propertyId String
  expiresAt DateTime?
  isPinned  Boolean   @default(false)

  content  Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id])

  @@index([propertyId])
  @@index([expiresAt])
}

model Attachment {
  id               String         @id @default(cuid())
  contentId        String
  contentType      ContentType    // SOP, MEMO, DOCUMENT, etc. — denormalized for query perf
  kind             AttachmentKind // IMAGE or DOCUMENT
  originalFileName String
  storedFileName   String
  mimeType         String
  fileSize         Int            // bytes
  storageKey       String         @unique // full path in bucket
  storageBucket    String
  uploadedById     String
  sortOrder        Int            @default(0)
  isInline         Boolean        @default(false) // true = inline/gallery, false = attachment
  caption          String?
  createdAt        DateTime       @default(now())

  content    Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  uploadedBy User    @relation("AttachmentUploadedBy", fields: [uploadedById], references: [id])

  @@index([contentId])
  @@index([contentType])
  @@index([uploadedById])
  @@index([createdAt])
  @@index([contentId, kind, sortOrder])
}

model StaticDocument {
  id         String             @id @default(cuid())
  type       StaticDocumentType
  title      String
  fileUrl    String
  propertyId String?
  uploadedAt DateTime           @default(now())

  property Property? @relation(fields: [propertyId], references: [id])

  @@index([propertyId])
  @@index([type])
}
