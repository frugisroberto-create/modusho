generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OPERATOR
  HOD
  HOTEL_MANAGER
  CORPORATE
  ADMIN
  SUPER_ADMIN
}

enum ContentType {
  SOP
  DOCUMENT
  MEMO
  BRAND_BOOK
  STANDARD_BOOK
}

enum ContentStatus {
  DRAFT
  REVIEW_HM
  REVIEW_ADMIN
  PUBLISHED
  RETURNED
  ARCHIVED
}

enum ReviewAction {
  APPROVED
  RETURNED
  FORWARDED
}

enum StaticDocumentType {
  BRAND_BOOK
  STANDARD_BOOK
  DOCUMENT
}

enum TargetType {
  ROLE
  DEPARTMENT
  USER
}

enum AttachmentKind {
  IMAGE
  DOCUMENT
}

enum SopStatus {
  IN_LAVORAZIONE
  PUBBLICATA
  ARCHIVIATA
}

enum SopEventType {
  DRAFT_CREATED
  TEXT_SAVED
  NOTE_ADDED
  ATTACHMENT_ADDED
  ATTACHMENT_REMOVED
  ATTACHMENT_REPLACED
  SUBMITTED_TO_C
  SUBMITTED_TO_A
  SUBMITTED_TO_C_AND_A
  C_CONSULTATION_CONFIRMED
  RETURNED_BY_A
  APPROVED
  PUBLISHED
  REVIEW_DUE_DATE_CHANGED
  ARCHIVED
}

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  name         String
  passwordHash String
  role         Role    @default(OPERATOR)
  canView      Boolean @default(true)
  canEdit      Boolean @default(false)
  canApprove   Boolean @default(false)
  isActive     Boolean @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  propertyAssignments  PropertyAssignment[]
  contentPermissions   UserContentPermission[]
  createdContents      Content[]              @relation("ContentCreatedBy")
  updatedContents      Content[]              @relation("ContentUpdatedBy")
  submittedContents    Content[]              @relation("ContentSubmittedBy")
  deletedContents      Content[]              @relation("ContentDeletedBy")
  featuredContents     Content[]              @relation("ContentFeaturedBy")
  acknowledgments      ContentAcknowledgment[]
  reviews              ContentReview[]
  statusChanges        ContentStatusHistory[] @relation("StatusChangedBy")
  contentRevisions     ContentRevision[]      @relation("ContentRevisedBy")
  contentNotes         ContentNote[]          @relation("ContentNoteAuthor")
  targetedContents     ContentTarget[]        @relation("ContentTargetUser")
  attachments          Attachment[]           @relation("AttachmentUploadedBy")

  sopWorkflowsAsR      SopWorkflow[]          @relation("SopResponsible")
  sopWorkflowsAsC      SopWorkflow[]          @relation("SopConsulted")
  sopWorkflowsAsA      SopWorkflow[]          @relation("SopAccountable")
  sopTextVersions      SopTextVersion[]       @relation("SopTextVersionSavedBy")
  sopWorkflowEvents    SopWorkflowEvent[]     @relation("SopWorkflowEventActor")
  sopViewRecords       SopViewRecord[]        @relation("SopViewRecordUser")
  pushSubscriptions    PushSubscription[]     @relation("PushSubscriptionUser")
  notifications        Notification[]

  @@index([role])
  @@index([email])
}

model UserContentPermission {
  id          String      @id @default(cuid())
  userId      String
  contentType ContentType

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, contentType])
  @@index([userId])
}

model Property {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  tagline     String?
  city        String
  address     String?
  description String?  @db.Text
  website     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  departments         Department[]
  propertyAssignments PropertyAssignment[]
  contents            Content[]
  memos               Memo[]
  staticDocuments     StaticDocument[]

  @@index([code])
}

model Department {
  id         String   @id @default(cuid())
  name       String
  code       String
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])

  propertyAssignments PropertyAssignment[]
  contents            Content[]
  contentTargets      ContentTarget[]       @relation("ContentTargetDepartment")

  @@unique([propertyId, code])
  @@index([propertyId])
}

model PropertyAssignment {
  id           String      @id @default(cuid())
  userId       String
  propertyId   String
  departmentId String?

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  department Department? @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId, departmentId])
  @@index([userId])
  @@index([propertyId])
  @@index([departmentId])
}

model Content {
  id           String        @id @default(cuid())
  code         String?       @unique
  type         ContentType
  title        String
  body         String
  fileUrl      String?
  status       ContentStatus @default(DRAFT)
  version      Int           @default(1)
  propertyId   String
  departmentId String?
  createdById   String
  updatedById   String
  submittedById String?
  isFeatured      Boolean       @default(false)
  featuredAt      DateTime?
  featuredById    String?
  standardSource  String?       // "HO_BRAND" | "LQA" | null — solo per STANDARD_BOOK
  isDeleted     Boolean       @default(false)
  deletedAt     DateTime?
  deletedById   String?
  publishedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  property    Property    @relation(fields: [propertyId], references: [id])
  department  Department? @relation(fields: [departmentId], references: [id])
  createdBy   User        @relation("ContentCreatedBy", fields: [createdById], references: [id])
  updatedBy   User        @relation("ContentUpdatedBy", fields: [updatedById], references: [id])
  submittedBy User?       @relation("ContentSubmittedBy", fields: [submittedById], references: [id])
  featuredBy  User?       @relation("ContentFeaturedBy", fields: [featuredById], references: [id])
  deletedBy   User?       @relation("ContentDeletedBy", fields: [deletedById], references: [id])

  acknowledgments  ContentAcknowledgment[]
  reviews          ContentReview[]
  statusHistory    ContentStatusHistory[]
  targetAudience   ContentTarget[]
  revisions        ContentRevision[]
  notes            ContentNote[]
  attachments      Attachment[]
  memo             Memo?
  sopWorkflow      SopWorkflow?
  sopViewRecords   SopViewRecord[]        @relation("SopViewRecords")

  @@index([propertyId])
  @@index([departmentId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@index([publishedAt])
  @@index([propertyId, status])
  @@index([propertyId, departmentId, status])
  @@index([propertyId, type, status])
}

model ContentAcknowledgment {
  id             String   @id @default(cuid())
  contentId      String
  userId         String
  acknowledgedAt DateTime @default(now())
  required       Boolean  @default(true)

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([contentId, userId])
  @@index([contentId])
  @@index([userId])
}

model ContentReview {
  id         String       @id @default(cuid())
  contentId  String
  reviewerId String
  action     ReviewAction
  note       String?
  createdAt  DateTime     @default(now())

  content  Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  reviewer User    @relation(fields: [reviewerId], references: [id])

  @@index([contentId])
  @@index([reviewerId])
}

model ContentStatusHistory {
  id          String         @id @default(cuid())
  contentId   String
  fromStatus  ContentStatus?
  toStatus    ContentStatus
  changedById String
  changedAt   DateTime       @default(now())
  note        String?

  content   Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  changedBy User    @relation("StatusChangedBy", fields: [changedById], references: [id])

  @@index([contentId])
  @@index([changedById])
  @@index([changedAt])
}

model ContentRevision {
  id             String        @id @default(cuid())
  contentId      String
  revisedById    String
  previousTitle  String
  previousBody   String        @db.Text
  newTitle       String
  newBody        String        @db.Text
  note           String?
  status         ContentStatus
  createdAt      DateTime      @default(now())

  content   Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  revisedBy User    @relation("ContentRevisedBy", fields: [revisedById], references: [id])

  @@index([contentId, createdAt])
}

model ContentNote {
  id        String   @id @default(cuid())
  contentId String
  authorId  String
  body      String   @db.Text
  createdAt DateTime @default(now())

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  author  User    @relation("ContentNoteAuthor", fields: [authorId], references: [id])

  @@index([contentId, createdAt])
  @@index([authorId])
}

model ContentTarget {
  id                 String      @id @default(cuid())
  contentId          String
  targetType         TargetType
  targetRole         Role?
  targetDepartmentId String?
  targetUserId       String?
  createdAt          DateTime    @default(now())

  content          Content     @relation(fields: [contentId], references: [id], onDelete: Cascade)
  targetDepartment Department? @relation("ContentTargetDepartment", fields: [targetDepartmentId], references: [id])
  targetUser       User?       @relation("ContentTargetUser", fields: [targetUserId], references: [id])

  @@index([contentId])
}

model Memo {
  id        String    @id @default(cuid())
  contentId String    @unique
  propertyId String
  expiresAt DateTime?
  isPinned  Boolean   @default(false)

  content  Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id])

  @@index([propertyId])
  @@index([expiresAt])
}

model Attachment {
  id               String         @id @default(cuid())
  contentId        String
  contentType      ContentType    // SOP, MEMO, DOCUMENT, etc. — denormalized for query perf
  kind             AttachmentKind // IMAGE or DOCUMENT
  originalFileName String
  storedFileName   String
  mimeType         String
  fileSize         Int            // bytes
  storageKey       String         @unique // full path in bucket
  storageBucket    String
  uploadedById     String
  sortOrder        Int            @default(0)
  isInline         Boolean        @default(false) // true = inline/gallery, false = attachment
  caption          String?
  createdAt        DateTime       @default(now())

  content    Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  uploadedBy User    @relation("AttachmentUploadedBy", fields: [uploadedById], references: [id])

  @@index([contentId])
  @@index([contentType])
  @@index([uploadedById])
  @@index([createdAt])
  @@index([contentId, kind, sortOrder])
}

model StaticDocument {
  id         String             @id @default(cuid())
  type       StaticDocumentType
  title      String
  fileUrl    String
  propertyId String?
  uploadedAt DateTime           @default(now())

  property Property? @relation(fields: [propertyId], references: [id])

  @@index([propertyId])
  @@index([type])
}

// ─── SOP RACI Workflow ───────────────────────────────────────────────

model SopWorkflow {
  id            String    @id @default(cuid())
  contentId     String    @unique
  sopStatus     SopStatus @default(IN_LAVORAZIONE)

  // RACI roles
  responsibleId String
  consultedId   String?
  accountableId String

  // Current flags — sottoposizione a C e/o A
  submittedToC     Boolean   @default(false)
  submittedToCAt   DateTime?
  submittedToCById String?
  submittedToA     Boolean   @default(false)
  submittedToAAt   DateTime?
  submittedToAById String?

  // Conferma consultazione C (valida per versione corrente)
  consultedConfirmedAt      DateTime?
  consultedConfirmedById    String?
  consultedConfirmedVersion Int?
  consultedConfirmedNote    String?

  // Review lifecycle
  reviewDueDate        DateTime?
  reviewDueDateSetById String?
  reviewDueMonths      Int       @default(12)

  // Concurrency / last save tracking
  lastSavedAt   DateTime?
  lastSavedById String?
  textVersionCount Int @default(0)

  // Visualizzazione version-aware: la versione pubblicata corrente richiede nuova conferma?
  requiresNewAcknowledgment Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  content     Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  responsible User    @relation("SopResponsible", fields: [responsibleId], references: [id])
  consulted   User?   @relation("SopConsulted", fields: [consultedId], references: [id])
  accountable User    @relation("SopAccountable", fields: [accountableId], references: [id])

  textVersions   SopTextVersion[]
  workflowEvents SopWorkflowEvent[]

  @@index([sopStatus])
  @@index([responsibleId])
  @@index([accountableId])
  @@index([reviewDueDate])
}

model SopTextVersion {
  id            String   @id @default(cuid())
  sopWorkflowId String
  versionNumber Int
  title         String
  body          String   @db.Text
  savedById     String
  createdAt     DateTime @default(now())

  sopWorkflow SopWorkflow @relation(fields: [sopWorkflowId], references: [id], onDelete: Cascade)
  savedBy     User        @relation("SopTextVersionSavedBy", fields: [savedById], references: [id])

  @@unique([sopWorkflowId, versionNumber])
  @@index([sopWorkflowId, createdAt])
}

model SopWorkflowEvent {
  id            String       @id @default(cuid())
  sopWorkflowId String
  eventType     SopEventType
  actorId       String
  note          String?      @db.Text
  metadata      Json?
  createdAt     DateTime     @default(now())

  sopWorkflow SopWorkflow @relation(fields: [sopWorkflowId], references: [id], onDelete: Cascade)
  actor       User        @relation("SopWorkflowEventActor", fields: [actorId], references: [id])

  @@index([sopWorkflowId, createdAt])
  @@index([actorId])
}

// ─── Registro visualizzazioni SOP (version-aware) ────────────────────

model SopViewRecord {
  id              String    @id @default(cuid())
  contentId       String
  userId          String
  contentVersion  Int       // Content.version al momento della visualizzazione
  viewedAt        DateTime  @default(now())
  acknowledgedAt  DateTime? // null = visto ma non confermato formalmente

  content Content @relation("SopViewRecords", fields: [contentId], references: [id], onDelete: Cascade)
  user    User    @relation("SopViewRecordUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([contentId, userId, contentVersion])
  @@index([contentId])
  @@index([userId])
  @@index([contentId, contentVersion])
}

// ─── Push Subscription (PWA) ──────────────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation("PushSubscriptionUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── In-App Notifications ──────────────────────────────────────────

enum NotificationType {
  CONTENT_PUBLISHED
  TEXT_SAVED
  NOTE_ADDED
  SUBMITTED
  ACK_REMINDER
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  url       String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
}
